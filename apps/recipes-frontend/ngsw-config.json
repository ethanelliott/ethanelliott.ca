{
  "$schema": "../../node_modules/@angular/service-worker/config/schema.json",
  "index": "/index.html",
  "assetGroups": [
    {
      "name": "app",
      "installMode": "prefetch",
      "updateMode": "prefetch",
      "resources": {
        "files": [
          "/favicon.ico",
          "/index.html",
          "/manifest.webmanifest",
          "/*.css",
          "/*.js"
        ]
      }
    },
    {
      "name": "assets",
      "installMode": "lazy",
      "updateMode": "prefetch",
      "resources": {
        "files": [
          "/icons/**",
          "/*.(svg|cur|jpg|jpeg|png|apng|webp|avif|gif|otf|ttf|woff|woff2)",
          "/**/*.(woff|woff2|ttf|otf|eot)"
        ]
      }
    },
    {
      "name": "google-fonts",
      "installMode": "lazy",
      "updateMode": "prefetch",
      "resources": {
        "urls": [
          "https://fonts.googleapis.com/**",
          "https://fonts.gstatic.com/**"
        ]
      }
    }
  ],
  "dataGroups": [
    {
      "name": "recipe-photos",
      "urls": ["https://recipes-service.elliott.haus/recipes/photos/**"],
      "cacheConfig": {
        "strategy": "performance",
        "maxSize": 600,
        "maxAge": "90d"
      }
    },
    {
      "name": "recipes-data",
      "urls": [
        "https://recipes-service.elliott.haus/recipes",
        "https://recipes-service.elliott.haus/recipes?**",
        "https://recipes-service.elliott.haus/recipes/**",
        "https://recipes-service.elliott.haus/categories",
        "https://recipes-service.elliott.haus/categories/**",
        "https://recipes-service.elliott.haus/tags",
        "https://recipes-service.elliott.haus/tags/**"
      ],
      "cacheConfig": {
        "strategy": "freshness",
        "maxSize": 400,
        "maxAge": "30d",
        "timeout": "3s"
      }
    }
  ],
  "navigationUrls": ["/**", "!/**/*.*", "!/**/_*", "!/**/_*/**"]
}
