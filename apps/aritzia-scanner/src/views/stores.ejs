<!DOCTYPE html>
<html lang="en">
  <head>
    <%- include('partials/head') %>
  </head>
  <body>
    <%- include('partials/nav') %>

    <h1><%= title %></h1>

    <% if (storeGroups && storeGroups.length > 0) { %>
    <p class="results-count"><%= totalStores %> stores tracked</p>

    <% storeGroups.forEach(group => { %>
    <h2><%= group.label %> (<%= group.stores.length %>)</h2>
    <div class="stores-grid">
      <% group.stores.forEach(store => { %>
      <a href="/stores/<%= store.id %>" class="store-card">
        <h3><%= store.name !== 'Unknown' ? store.name : `Store #${store.id}` %></h3>
        <% if (store.city) { %>
        <p class="store-location"><%= store.city %>, <%= store.province %></p>
        <% } %>
        <p class="store-stats"><%= store.variant_count %> items in stock</p>
      </a>
      <% }); %>
    </div>
    <% }); %>

    <% } else { %>
    <%- include('partials/empty_state', { message: 'No store data available yet. Store availability is populated during data updates.', icon: '🏬' }) %>
    <% } %>
  </body>
</html>
