<!DOCTYPE html>
<html lang="en">
  <head>
    <%- include('partials/head') %>
  </head>
  <body>
    <%- include('partials/nav') %>

    <h1><%= title %></h1>

    <% if (cards && cards.length > 0) { %>
    <p class="results-count"><%= totalCount.toLocaleString() %> discontinued item<%= totalCount === 1 ? '' : 's' %></p>
    <div class="product-grid">
      <% cards.forEach(card => { %>
      <%- include('partials/product_card', { card }) %>
      <% }); %>
    </div>
    <% } else { %>
    <%- include('partials/empty_state', { message: 'Nothing has been discontinued yet.', icon: '👀' }) %>
    <% } %>

    <%- include('partials/pagination', {
      page,
      totalPages,
      baseUrl: '/discontinued',
      query: {},
    }) %>
  </body>
</html>
