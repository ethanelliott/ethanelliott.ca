<!DOCTYPE html>
<html lang="en">
  <head>
    <%- include('partials/head') %>
  </head>
  <body>
    <%- include('partials/nav') %>

    <h1><%= title %></h1>

    <% if (categories && categories.length > 0) { %>
    <p class="results-count"><%= categories.length %> categories</p>
    <div class="categories-grid">
      <% categories.forEach(cat => { %>
      <a href="/categories/<%= encodeURIComponent(cat.name) %>" class="category-card">
        <h3><%= cat.name %></h3>
        <div class="category-stats">
          <span class="active-count"><%= cat.activeCount %> active</span>
          <% if (cat.count - cat.activeCount > 0) { %>
          <span class="inactive-count"><%= cat.count - cat.activeCount %> discontinued</span>
          <% } %>
        </div>
      </a>
      <% }); %>
    </div>
    <% } else { %>
    <%- include('partials/empty_state', { message: 'No categories tracked yet.', icon: '🗂️' }) %>
    <% } %>
  </body>
</html>
