<!DOCTYPE html>
<html lang="en">
  <head>
    <%- include('partials/head') %>
  </head>
  <body>
    <%- include('partials/nav') %>

    <h1><%= title %></h1>
    <p><a href="/categories" class="back-link">&larr; Back to all categories</a></p>

    <!-- Sort -->
    <form action="/categories/<%= encodeURIComponent(category) %>" method="GET" class="filters-form">
      <select name="sort" class="filter-input" aria-label="Sort">
        <option value="reviews" <%= currentSort === 'reviews' ? 'selected' : '' %>>Most Reviews</option>
        <option value="rating" <%= currentSort === 'rating' ? 'selected' : '' %>>Highest Rated</option>
        <option value="price-low" <%= currentSort === 'price-low' ? 'selected' : '' %>>Price: Low</option>
        <option value="price-high" <%= currentSort === 'price-high' ? 'selected' : '' %>>Price: High</option>
      </select>
    </form>

    <% if (cards && cards.length > 0) { %>
    <p class="results-count"><%= cards.length %> product<%= cards.length === 1 ? '' : 's' %></p>
    <div class="product-grid">
      <% cards.forEach(card => { %>
      <%- include('partials/product_card', { card }) %>
      <% }); %>
    </div>
    <% } else { %>
    <%- include('partials/empty_state', { message: 'No products in this category.', icon: '🗂️' }) %>
    <% } %>
  </body>
</html>
