<!DOCTYPE html>
<html lang="en">
  <head>
    <%- include('partials/head') %>
  </head>
  <body>
    <%- include('partials/nav') %>

    <% if (typeof backHref !== 'undefined' && backHref) { %>
    <p class="results-count"><a href="<%= backHref %>">&larr; Back to changelog</a></p>
    <% } %>
    <h1><%= title %></h1>
    <% if (typeof subtitle !== 'undefined' && subtitle) { %>
    <p class="results-count"><%= subtitle %></p>
    <% } %>

    <%
      const sections = [
        { title: 'New Products', icon: '🆕', cards: newProductCards },
        { title: 'New Colors', icon: '🎨', cards: newColorCards },
        { title: 'Restocks', icon: '📦', cards: restockCards },
        { title: 'Price Drops', icon: '💸', cards: priceDropCards },
      ];
      const totalChanges = sections.reduce((n, s) => n + s.cards.length, 0);
    %>

    <% if (totalChanges === 0) { %>
    <%- include('partials/empty_state', { message: 'Nothing changed in the last scan. Check back later!', icon: '✨' }) %>
    <% } else { %>
      <% sections.forEach(section => { %>
        <% if (section.cards.length > 0) { %>
        <section class="whats-new-section">
          <h2><%= section.icon %> <%= section.title %> (<%= section.cards.length %>)</h2>
          <div class="product-grid">
            <% section.cards.forEach(card => { %>
            <%- include('partials/product_card', { card }) %>
            <% }); %>
          </div>
        </section>
        <% } %>
      <% }); %>
    <% } %>
  </body>
</html>
