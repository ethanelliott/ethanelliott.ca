<!DOCTYPE html>
<html lang="en">
  <head>
    <%- include('partials/head') %>
  </head>
  <body>
    <%- include('partials/nav') %>

    <div class="new-to-me-header">
      <h1><%= title %></h1>
      <button id="mark-seen-btn" class="view-all-button" style="display: none">
        Mark all as seen
      </button>
    </div>
    <p class="results-count" id="new-to-me-count"></p>
    <p class="muted-note">
      Products added since you last caught up. Tracked per browser, so this
      stays in sync on this device only.
    </p>

    <div id="new-to-me-empty" class="empty-state" style="display: none">
      <div class="empty-state-icon">✨</div>
      <p class="empty-state-text">You're all caught up — nothing new to you.</p>
      <p><a href="/" class="view-all-button">Browse Products</a></p>
    </div>

    <div id="new-to-me-loading" class="skeleton-container">
      <div class="skeleton-shimmer"></div>
      <p class="skeleton-caption">Finding what's new to you...</p>
    </div>

    <div id="new-to-me-grid" class="product-grid" style="display: none"></div>

    <script>
      async function loadNewToMe() {
        const loading = document.getElementById('new-to-me-loading');
        const empty = document.getElementById('new-to-me-empty');
        const grid = document.getElementById('new-to-me-grid');
        const count = document.getElementById('new-to-me-count');
        const markBtn = document.getElementById('mark-seen-btn');

        const since = getSeenUntil();
        loading.style.display = 'block';
        empty.style.display = 'none';
        grid.style.display = 'none';
        markBtn.style.display = 'none';
        count.textContent = '';

        try {
          const resp = await fetch(
            '/api/new-products?since=' + encodeURIComponent(since)
          );
          const products = await resp.json();

          if (!Array.isArray(products) || products.length === 0) {
            loading.style.display = 'none';
            empty.style.display = 'block';
            return;
          }

          grid.innerHTML = products
            .map((p) =>
              renderProductCard({
                href: '/product/' + p.id,
                name: p.display_name || p.name,
                thumbnail_id: p.thumbnail_id,
                price: p.price,
                pricePrefix: 'From ',
                rating: p.rating,
                review_count: p.review_count,
                discontinued: !!p.isDiscontinued,
              })
            )
            .join('');

          count.textContent =
            products.length.toLocaleString() +
            ' new to you' +
            (products.length >= 500 ? ' (showing first 500)' : '');
          loading.style.display = 'none';
          grid.style.display = 'grid';
          markBtn.style.display = 'inline-block';
        } catch (err) {
          loading.innerHTML =
            '<p class="ai-error">Failed to load new items.</p>';
        }
      }

      document.getElementById('mark-seen-btn').addEventListener('click', () => {
        if (window.ARITZIA_LAST_SCAN) {
          setSeenUntil(window.ARITZIA_LAST_SCAN);
          updateNewCount();
          loadNewToMe();
        }
      });

      // app.js is deferred, so wait for it before using its helpers
      document.addEventListener('DOMContentLoaded', loadNewToMe);
    </script>
  </body>
</html>
