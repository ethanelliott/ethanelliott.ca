<!DOCTYPE html>
<html lang="en">
  <head>
    <%- include('partials/head') %>
  </head>
  <body>
    <%- include('partials/nav') %>

    <h1><%= title %></h1>

    <!-- Search and Filters -->
    <form action="<%= baseUrl %>" method="GET" class="filters-form">
      <input
        type="text"
        name="q"
        placeholder="Search products..."
        value="<%= searchQuery || '' %>"
        class="filter-input filter-search"
      />

      <% if (brands && brands.length > 0) { %>
      <select name="brand" class="filter-input" aria-label="Brand">
        <option value="">All Brands</option>
        <% brands.forEach(brand => { %>
        <option value="<%= brand %>" <%= currentBrand === brand ? 'selected' : '' %>><%= brand %></option>
        <% }); %>
      </select>
      <% } %>

      <% if (fits && fits.length > 0) { %>
      <select name="fit" class="filter-input" aria-label="Fit">
        <option value="">All Fits</option>
        <% fits.forEach(fit => { %>
        <option value="<%= fit %>" <%= currentFit === fit ? 'selected' : '' %>><%= fit %></option>
        <% }); %>
      </select>
      <% } %>

      <% if (categories && categories.length > 0) { %>
      <select name="category" class="filter-input" aria-label="Category">
        <option value="">All Categories</option>
        <% categories.forEach(cat => { %>
        <option value="<%= cat %>" <%= currentCategory === cat ? 'selected' : '' %>><%= cat %></option>
        <% }); %>
      </select>
      <% } %>

      <% if (sizes && sizes.length > 0) { %>
      <select name="size" class="filter-input" aria-label="Size">
        <option value="">All Sizes</option>
        <% sizes.forEach(size => { %>
        <option value="<%= size %>" <%= currentSize === size ? 'selected' : '' %>><%= size %></option>
        <% }); %>
      </select>
      <% } %>

      <% if (showPriceFilters) { %>
      <input
        type="number"
        name="minPrice"
        placeholder="Min $"
        min="0"
        step="1"
        value="<%= minPrice !== null && minPrice !== undefined ? minPrice : '' %>"
        class="filter-input filter-price"
        aria-label="Minimum price"
      />
      <input
        type="number"
        name="maxPrice"
        placeholder="Max $"
        min="0"
        step="1"
        value="<%= maxPrice !== null && maxPrice !== undefined ? maxPrice : '' %>"
        class="filter-input filter-price"
        aria-label="Maximum price"
      />
      <% } %>

      <select name="sort" class="filter-input" aria-label="Sort">
        <% sortOptions.forEach(opt => { %>
        <option value="<%= opt.value %>" <%= currentSort === opt.value ? 'selected' : '' %>><%= opt.label %></option>
        <% }); %>
      </select>

      <button type="submit" class="filter-btn">Apply</button>
      <a href="<%= baseUrl %>" class="filter-clear">Clear</a>
    </form>

    <% if (cards && cards.length > 0) { %>
    <p class="results-count"><%= totalCount.toLocaleString() %> result<%= totalCount === 1 ? '' : 's' %></p>
    <div class="product-grid">
      <% cards.forEach(card => { %>
      <%- include('partials/product_card', { card }) %>
      <% }); %>
    </div>
    <% } else { %>
    <%- include('partials/empty_state', { message: emptyMessage }) %>
    <% } %>

    <%- include('partials/pagination', {
      page,
      totalPages,
      baseUrl,
      query: {
        q: searchQuery,
        brand: currentBrand,
        fit: currentFit,
        category: currentCategory,
        size: currentSize,
        minPrice,
        maxPrice,
        sort: currentSort !== defaultSort ? currentSort : null,
      },
    }) %>
  </body>
</html>
