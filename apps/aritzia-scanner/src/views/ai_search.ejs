<!DOCTYPE html>
<html lang="en">
  <head>
    <%- include('partials/head') %>
  </head>
  <body>
    <%- include('partials/nav') %>

    <h1>AI Search</h1>
    <p class="ai-subtitle">
      Describe what you're looking for in natural language
    </p>

    <form
      id="ai-search-form"
      class="filters-form"
      onsubmit="return handleSearch(event)"
    >
      <input
        type="text"
        id="ai-search-input"
        name="q"
        placeholder="e.g. warm cozy sweater under $100 in neutral colors..."
        class="filter-input filter-search ai-search-input"
        autocomplete="off"
      />
      <button type="submit" class="filter-btn" id="ai-search-btn">
        Search
      </button>
    </form>

    <div id="ai-thinking" class="ai-stream-container" style="display: none">
      <div class="ai-thinking-header">
        <span class="ai-thinking-icon">🤖</span>
        <span id="ai-search-status">Understanding your query...</span>
      </div>
      <div id="ai-reasoning" class="ai-reasoning" style="display: none"></div>
      <div id="ai-filters" class="ai-filters-display" style="display: none"></div>
    </div>

    <div id="ai-results" style="display: none">
      <h2 id="results-heading"></h2>
      <p id="ai-explanation" class="ai-explanation"></p>
      <div id="results-grid" class="product-grid"></div>
    </div>

    <div id="ai-error" class="ai-error" style="display: none"></div>

    <script>
      function handleSearch(e) {
        e.preventDefault();
        const query = document.getElementById('ai-search-input').value.trim();
        if (query.length < 3) return false;

        const btn = document.getElementById('ai-search-btn');
        btn.disabled = true;
        btn.textContent = 'Searching...';

        const reasoningEl = document.getElementById('ai-reasoning');
        document.getElementById('ai-thinking').style.display = 'block';
        document.getElementById('ai-search-status').textContent =
          'Understanding your query...';
        document.getElementById('ai-results').style.display = 'none';
        document.getElementById('ai-error').style.display = 'none';
        reasoningEl.style.display = 'none';
        reasoningEl.textContent = '';
        reasoningEl.classList.remove('reasoning-collapsed');
        document.getElementById('ai-filters').style.display = 'none';

        const evtSource = new EventSource(
          `/api/ai/search?q=${encodeURIComponent(query)}`
        );

        evtSource.addEventListener('status', (e) => {
          document.getElementById('ai-search-status').textContent =
            JSON.parse(e.data).message;
        });

        evtSource.addEventListener('reasoning', (e) => {
          const data = JSON.parse(e.data);
          reasoningEl.style.display = 'block';
          reasoningEl.classList.add('thinking-active');
          reasoningEl.textContent += data.content;
          reasoningEl.scrollTop = reasoningEl.scrollHeight;
        });

        evtSource.addEventListener('reasoning-done', () => {
          reasoningEl.classList.add('reasoning-collapsed');
        });

        evtSource.addEventListener('filters', (e) => {
          const data = JSON.parse(e.data);
          const filtersEl = document.getElementById('ai-filters');
          if (data.filters && Object.keys(data.filters).length > 0) {
            filtersEl.style.display = 'block';
            const f = data.filters;
            const parts = [];
            if (f.searchTerms?.length)
              parts.push(`Keywords: ${f.searchTerms.join(', ')}`);
            if (f.brand) parts.push(`Brand: ${f.brand}`);
            if (f.category) parts.push(`Category: ${f.category}`);
            if (f.color) parts.push(`Color: ${f.color}`);
            if (f.size) parts.push(`Size: ${f.size}`);
            if (f.minPrice != null) parts.push(`Min: $${f.minPrice}`);
            if (f.maxPrice != null) parts.push(`Max: $${f.maxPrice}`);
            if (f.onSale) parts.push('On Sale');
            if (f.sortBy) parts.push(`Sort: ${f.sortBy}`);
            // Filter values come from model output — escape before innerHTML
            filtersEl.innerHTML =
              '<strong>Interpreted filters:</strong> ' +
              parts
                .map((p) => `<span class="ai-filter-tag">${escapeHtml(p)}</span>`)
                .join(' ');
          }
        });

        evtSource.addEventListener('results', (e) => {
          const data = JSON.parse(e.data);
          const resultsEl = document.getElementById('ai-results');
          const gridEl = document.getElementById('results-grid');

          resultsEl.style.display = 'block';
          document.getElementById('results-heading').textContent = `Found ${
            data.count
          } result${data.count !== 1 ? 's' : ''}`;
          document.getElementById('ai-explanation').textContent =
            data.explanation || '';

          if (data.products.length === 0) {
            gridEl.innerHTML =
              '<div class="empty-state"><p class="empty-state-text">No products matched your search. Try a different description.</p></div>';
            return;
          }

          gridEl.innerHTML = data.products
            .map((p) =>
              renderProductCard({
                href: '/product/' + p.product_id + '/variant/' + p.color_id,
                name: p.display_name || p.name,
                thumbnail_id: p.thumbnail_id,
                price: p.price,
                list_price: p.list_price,
                subtext:
                  (p.color || '') +
                  (p.length && p.length !== 'REGULAR' ? ' (' + p.length + ')' : ''),
                favoriteId: p.id,
                rating: p.rating,
                review_count: p.review_count,
              })
            )
            .join('');
        });

        evtSource.addEventListener('error', (e) => {
          const errorEl = document.getElementById('ai-error');
          errorEl.style.display = 'block';
          try {
            errorEl.textContent = `Error: ${JSON.parse(e.data).error}`;
          } catch {
            errorEl.textContent = 'Connection lost. Please try again.';
          }
          evtSource.close();
          btn.disabled = false;
          btn.textContent = 'Search';
        });

        evtSource.addEventListener('done', () => {
          evtSource.close();
          btn.disabled = false;
          btn.textContent = 'Search';
          document.getElementById('ai-search-status').textContent =
            'Query processed';
        });

        evtSource.onerror = () => {
          evtSource.close();
          btn.disabled = false;
          btn.textContent = 'Search';
        };

        return false;
      }
    </script>
  </body>
</html>
